						"salt": "Secret random bytes32 value."
					}
				}
			},
			"title": "Signed sealed-bid auction",
			"version": 1
		},
		"userdoc": {
			"kind": "user",
			"methods": {
				"commitBid(address,bytes32,uint256,uint256,bytes)": {
					"notice": "Submits a signed commitment."
				},
				"finalize()": {
					"notice": "Finishes the auction after the reveal period."
				},
				"getCommitAuthorizationDigest(address,bytes32,uint256,uint256)": {
					"notice": "Returns the prefixed digest used by ecrecover."
				},
				"getCommitAuthorizationHash(address,bytes32,uint256,uint256)": {
					"notice": "Returns the value the bidder signs off-chain."
				},
				"makeCommitment(address,uint256,bytes32)": {
					"notice": "Creates the commitment for a private bid."
				},
				"phase()": {
					"notice": "Returns the current auction phase."
				},
				"revealBid(uint256,bytes32)": {
					"notice": "Reveals the bid and deposits exactly bidAmount wei."
				},
				"withdraw()": {
					"notice": "Withdraws refunds or seller proceeds."
				}
			},
			"notice": "Educational example:         1. A bidder creates a private commitment.         2. The bidder signs authorization for that commitment.         3. Any relayer can submit the signed commitment.         4. The bidder reveals the bid and deposits ETH.         5. Losing bidders can withdraw their ETH.",
			"version": 1
		}
